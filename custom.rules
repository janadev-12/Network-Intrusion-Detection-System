# NetShield IDS - Custom Suricata Rules
# Educational / Portfolio Purpose

alert tcp any any -> any 22 (msg:"Possible SSH Brute Force Attempt"; flow:to_server; threshold:type both, track by_src, count 5, seconds 60; sid:100001; rev:1;)

alert tcp any any -> any 80 (msg:"SQL Injection Pattern Detected"; content:"union select"; nocase; sid:100002; rev:1;)

alert tcp any any -> any 445 (msg:"Suspicious SMB Connection"; sid:100003; rev:1;)

alert tcp any any -> any any (msg:"Port Scan Activity Detected"; flags:S; threshold:type both, track by_src, count 20, seconds 10; sid:100004; rev:1;)

alert udp any any -> any 53 (msg:"Suspicious DNS Query"; content:"malicious"; nocase; sid:100005; rev:1;)

alert tcp any any -> any 443 (msg:"Malware Traffic Pattern Detected"; content:"trojan"; nocase; sid:100006; rev:1;)

alert tcp any any -> any 3389 (msg:"RDP Login Attack Attempt"; sid:100007; rev:1;)